# ─── StarChart App — Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in your real values before deploying.
# The app runs fully in demo/mock mode without any of these keys.

# Stripe (payments)
# Get keys at: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE

# Firebase (push notifications)
# Get config at: https://console.firebase.google.com
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=

# Backend API (when you add a server)
VITE_API_BASE_URL=http://localhost:3001
